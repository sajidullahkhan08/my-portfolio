# ==========================
# Root .gitignore
# ==========================

# --- Dependencies ---
node_modules/
.pnp
.pnp.js

# --- Environment Variables ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# --- Build Outputs ---
dist/
build/
out/

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- OS Files ---
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
*.swp
*.swo
*~

# --- IDE / Editor ---
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace
.project
.classpath
.settings/

# --- Testing ---
coverage/
*.lcov
.nyc_output/

# --- Misc ---
*.tgz
*.tar.gz
*.zip
.cache/
.temp/
.tmp/
